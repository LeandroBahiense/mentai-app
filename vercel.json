{
  "rewrites": [
    { "source": "/app", "destination": "/index.html" },
    { "source": "/app/(.*)", "destination": "/index.html" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/", "destination": "/landing.html" }
  ],
  "crons": [
    { "path": "/api/cron/briefing", "schedule": "0 11 * * *" }
  ]
}
